# .env.example

# bunq environment: "sandbox" | "production"
BUNQ_ENV=sandbox

# bunq API credentials
BUNQ_API_KEY=
BUNQ_DEVICE_DESCRIPTION=KairosFinance-Dev

# bunq sandbox base URL
BUNQ_SANDBOX_URL=https://public-api.sandbox.bunq.com/v1
BUNQ_PRODUCTION_URL=https://api.bunq.com/v1

# Anthropic
ANTHROPIC_API_KEY=

# Ollama (local embeddings)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ElevenLabs (STT + TTS)
ELEVENLABS_API_KEY=
# Optional: override the TTS voice (default: Sarah — EXAVITQu4vr4xnSDxMaL)
ELEVENLABS_VOICE_ID=

# Database
DB_PATH=./bunqsy.db

# Server
PORT=3001
WS_PORT=3002

# Webhook push URL — set to your public HTTPS base URL (ngrok or prod domain).
# When set, the daemon registers PAYMENT + MUTATION notification filters with bunq
# on startup so payments trigger instant heartbeat ticks instead of waiting for polling.
# Example: WEBHOOK_PUBLIC_URL=https://abc123.ngrok.io
WEBHOOK_PUBLIC_URL=

# KAIROS Score weights (tune as needed)
SCORE_WEIGHT_BALANCE=0.35
SCORE_WEIGHT_VELOCITY=0.25
SCORE_WEIGHT_GOALS=0.25
SCORE_WEIGHT_UPCOMING=0.15


# ─── Bookkeeping ──────────────────────────────────────────────────────────────
BOOKKEEPING_AUTO_CATEGORIZE=true
REVIEW_THRESHOLD_AMOUNT_CENTS=50000
LLM_CATEGORIZE_CONFIDENCE_THRESHOLD=0.70
